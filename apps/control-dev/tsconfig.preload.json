{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022", "DOM"],
    "outDir": "dist/preload",
    "rootDir": "preload",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["preload/**/*.ts"]
}
