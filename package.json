{
  "name": "nordrise-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Nordrise AI — Sean. Personal AI assistant on Claude Max via headless Claude Code CLI.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/gateway.js",
    "dev": "tsx watch src/gateway.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify-auth": "tsx scripts/verify-auth.ts",
    "bridge-repl": "tsx scripts/bridge-repl.ts",
    "set-webhook": "tsx scripts/set-webhook.ts",
    "gen-secret": "tsx scripts/gen-webhook-secret.ts",
    "issue-control-token": "tsx scripts/issue-control-token.ts",
    "sync-control-types": "tsx scripts/sync-control-types.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/client": "5.22.0",
    "dotenv": "16.4.5",
    "express": "4.21.2",
    "file-type": "^19.6.0",
    "grammy": "1.30.0",
    "multer": "^1.4.5-lts.1",
    "pino": "9.5.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "20.17.9",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "embedded-postgres": "^16.13.0-beta.17",
    "pino-pretty": "13.0.0",
    "prisma": "5.22.0",
    "supertest": "^7.0.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "^2.1.8"
  }
}
