generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id              String    @id @default(cuid())
  telegramChatId  BigInt    @unique
  claudeSessionId String?
  createdAt       DateTime  @default(now())
  lastActiveAt    DateTime  @updatedAt
  messages        Message[]

  @@index([lastActiveAt])
}

model ControlSession {
  id              String    @id @default(cuid())
  title           String?
  claudeSessionId String?
  createdAt       DateTime  @default(now())
  lastActiveAt    DateTime  @updatedAt
  archivedAt      DateTime?
  /// Per-thread system-prompt override. Appended after the global persona
  /// via --append-system-prompt in claudeBridge. NULL = use persona only.
  systemPrompt    String?   @db.Text
  /// Phase 3 — optional project tag. SetNull on Project delete so we
  /// never lose conversation history when a project goes away.
  projectId       String?
  project         Project?  @relation("ProjectSessions", fields: [projectId], references: [id], onDelete: SetNull)
  messages        Message[]
  tokenUsage      TokenUsage[]

  @@index([lastActiveAt])
  @@index([archivedAt])
  @@index([projectId, lastActiveAt])
}

model Message {
  id               String          @id @default(cuid())
  sessionId        String?
  controlSessionId String?
  session          Session?        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  controlSession   ControlSession? @relation(fields: [controlSessionId], references: [id], onDelete: Cascade)
  role             String
  content          String          @db.Text
  tokens           Int?
  durationMs       Int?
  createdAt        DateTime        @default(now())
  /// Pinned messages — surfaced via `Pinet` panel in the desktop app and
  /// listed in the global-search modal. Additive flag, defaults false.
  pinned           Boolean         @default(false)
  reaction         Reaction?

  @@index([sessionId, createdAt])
  @@index([controlSessionId, createdAt])
  @@index([pinned, createdAt])
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String   @unique
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  /// 'up' | 'down'
  value     String
  createdAt DateTime @default(now())
}

model MemoryNote {
  id        String   @id @default(cuid())
  date      DateTime @unique
  content   String   @db.Text
  createdAt DateTime @default(now())
}

model Routine {
  id          String   @id @default(cuid())
  name        String
  prompt      String   @db.Text
  schedule    String   // cron string, e.g. "0 9 * * 1" = Mon 09:00
  enabled     Boolean  @default(true)
  channel     String   @default("desktop")  // 'desktop' | 'telegram' | 'both'
  model       String?  // optional override; null = default
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastRunAt   DateTime?
  runs        RoutineRun[]

  @@index([enabled, schedule])
}

model RoutineRun {
  id          String    @id @default(cuid())
  routineId   String
  routine     Routine   @relation(fields: [routineId], references: [id], onDelete: Cascade)
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  status      String    // 'running' | 'success' | 'failed'
  result      String?   @db.Text
  errorMsg    String?   @db.Text
  durationMs  Int?

  @@index([routineId, startedAt])
}

model Suggestion {
  id          String   @id @default(cuid())
  type        String   // 'research' | 'cleanup' | 'check' | 'remind' | 'idea' | 'note'
  title       String   @db.Text
  rationale   String   @db.Text
  prompt      String   @db.Text   // what Sean would do if approved
  status      String   @default("pending")  // 'pending' | 'approved' | 'rejected' | 'done' | 'failed' | 'expired'
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  decidedAt   DateTime?
  executedAt  DateTime?
  result      String?  @db.Text
  errorMsg    String?  @db.Text
  durationMs  Int?

  @@index([status, expiresAt])
  @@index([createdAt])
}

/// Audit trail of every proactive engine tick. Every cron evaluation lands
/// here regardless of whether Sean ended up sending — `decision` distinguishes
/// the outcome (sent / skipped / rate_limited / quiet_hours / disabled). The
/// `category` taxonomy mirrors the JSON output of the meta-prompt.
model ProactiveAttempt {
  id          String   @id @default(cuid())
  triggeredAt DateTime @default(now())
  decision    String   // 'sent' | 'skipped' | 'rate_limited' | 'quiet_hours' | 'disabled'
  reason      String?  @db.Text
  message     String?  @db.Text
  category    String?  // 'question' | 'status' | 'idea' | 'observation' | 'check-in'
  costUsd     Float?

  @@index([triggeredAt])
  @@index([decision, triggeredAt])
}

/// Singleton row controlling the proactive engine's runtime behaviour.
/// `enabled=false` is the soft kill; PROACTIVE_DISABLED env is the hard kill.
/// Quiet hours: `quietHourStart` is inclusive, `quietHourEnd` is exclusive
/// (start=22, end=8 means hours 22, 23, 0..7 are quiet). Rate limits are per
/// rolling-hour and rolling-day windows.
model ProactiveSettings {
  id              String   @id @default(cuid())
  enabled         Boolean  @default(true)
  quietHourStart  Int      @default(22)
  quietHourEnd    Int      @default(8)
  maxPerHour      Int      @default(3)
  maxPerDay       Int      @default(10)
  cadenceMin      Int      @default(15)
  updatedAt       DateTime @updatedAt
}

/// Phase 3 — projects so the user can tag a thread with a context (e.g.
/// "Tid for Service" or "Happy Time") and the Costs panel can break
/// usage down per project. Default project is null (no tag); the desktop
/// UI shows that as "General". Per CLAUDE.md §12 + §6.17: every new
/// field is optional/defaulted so older gateway/client deploys see no
/// missing-required-field errors during a roll-out window.
model Project {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  sessions    ControlSession[] @relation("ProjectSessions")
  tokenUsage  TokenUsage[]
}

/// Per-stream token usage. Written by `messageRoute.ts` immediately
/// after the SSE `done` frame is sent. Cost is informational on the
/// Max subscription (the field is reported by claude-code but not
/// billed) — we still persist it so the Costs panel can show
/// "what would this have cost on the API". Cache-read tokens are
/// excluded from "session tokens" elsewhere (see costTracker.ts) but
/// stored here for completeness.
model TokenUsage {
  id                  String          @id @default(cuid())
  controlSessionId    String?
  controlSession      ControlSession? @relation(fields: [controlSessionId], references: [id], onDelete: Cascade)
  projectId           String?
  project             Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  inputTokens         Int             @default(0)
  outputTokens        Int             @default(0)
  cacheReadTokens     Int             @default(0)
  cacheCreationTokens Int             @default(0)
  costUsd             Float           @default(0)
  modelId             String?
  durationMs          Int?
  recordedAt          DateTime        @default(now())

  @@index([controlSessionId, recordedAt])
  @@index([projectId, recordedAt])
  @@index([recordedAt])
}

/// Sean's self-improvement proposals. The watcher cron analyses recent
/// usage data (messages / suggestions / routines / proactive attempts) and
/// drafts up to 3 specific app improvements per pass. The user approves
/// promising ones; an Opus-driven background task then writes a detailed
/// implementation spec to /app/workspace/sean-notes/app-improvements/<date>-<slug>.md
/// which the existing sean-notes -> vault sync surfaces in Obsidian.
model AppImprovement {
  id              String    @id @default(cuid())
  category        String    // 'bug-fix' | 'feature' | 'ux' | 'performance' | 'security'
  title           String
  description     String    @db.Text
  rationale       String    @db.Text
  patternEvidence String?   @db.Text
  proposedSpec    String?   @db.Text
  status          String    @default("pending") // 'pending' | 'approved' | 'spec-written' | 'rejected' | 'implemented'
  createdAt       DateTime  @default(now())
  approvedAt      DateTime?
  specWrittenAt   DateTime?
  vaultPath       String?

  @@index([status, createdAt])
  @@index([createdAt])
}
