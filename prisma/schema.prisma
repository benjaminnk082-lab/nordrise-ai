generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id              String    @id @default(cuid())
  telegramChatId  BigInt    @unique
  claudeSessionId String?
  createdAt       DateTime  @default(now())
  lastActiveAt    DateTime  @updatedAt
  messages        Message[]

  @@index([lastActiveAt])
}

model ControlSession {
  id              String    @id @default(cuid())
  title           String?
  claudeSessionId String?
  createdAt       DateTime  @default(now())
  lastActiveAt    DateTime  @updatedAt
  archivedAt      DateTime?
  messages        Message[]

  @@index([lastActiveAt])
  @@index([archivedAt])
}

model Message {
  id               String          @id @default(cuid())
  sessionId        String?
  controlSessionId String?
  session          Session?        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  controlSession   ControlSession? @relation(fields: [controlSessionId], references: [id], onDelete: Cascade)
  role             String
  content          String          @db.Text
  tokens           Int?
  durationMs       Int?
  createdAt        DateTime        @default(now())

  @@index([sessionId, createdAt])
  @@index([controlSessionId, createdAt])
}

model MemoryNote {
  id        String   @id @default(cuid())
  date      DateTime @unique
  content   String   @db.Text
  createdAt DateTime @default(now())
}

model Routine {
  id          String   @id @default(cuid())
  name        String
  prompt      String   @db.Text
  schedule    String   // cron string, e.g. "0 9 * * 1" = Mon 09:00
  enabled     Boolean  @default(true)
  channel     String   @default("desktop")  // 'desktop' | 'telegram' | 'both'
  model       String?  // optional override; null = default
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastRunAt   DateTime?
  runs        RoutineRun[]

  @@index([enabled, schedule])
}

model RoutineRun {
  id          String    @id @default(cuid())
  routineId   String
  routine     Routine   @relation(fields: [routineId], references: [id], onDelete: Cascade)
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  status      String    // 'running' | 'success' | 'failed'
  result      String?   @db.Text
  errorMsg    String?   @db.Text
  durationMs  Int?

  @@index([routineId, startedAt])
}

model Suggestion {
  id          String   @id @default(cuid())
  type        String   // 'research' | 'cleanup' | 'check' | 'remind' | 'idea' | 'note'
  title       String   @db.Text
  rationale   String   @db.Text
  prompt      String   @db.Text   // what Sean would do if approved
  status      String   @default("pending")  // 'pending' | 'approved' | 'rejected' | 'done' | 'failed' | 'expired'
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  decidedAt   DateTime?
  executedAt  DateTime?
  result      String?  @db.Text
  errorMsg    String?  @db.Text
  durationMs  Int?

  @@index([status, expiresAt])
  @@index([createdAt])
}
