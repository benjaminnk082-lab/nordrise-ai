# =============================================================================
# Nordrise AI — Sean. Environment variables.
# Copy to .env for local dev. In Railway, set each in the service dashboard.
# NEVER commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication — Claude Max subscription via OAuth token
# -----------------------------------------------------------------------------
# Generate locally with: claude setup-token
# Token is long-lived (approx. 1 year). Rotate manually before expiry.
# NEVER set ANTHROPIC_API_KEY — it forces paid per-token API billing.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-REPLACE_ME

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
# From @BotFather. Keep secret.
TELEGRAM_BOT_TOKEN=REPLACE_ME

# Random 32-byte hex string. Generate with: npm run gen-secret
# Telegram will include this in the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=REPLACE_ME

# -----------------------------------------------------------------------------
# Access control
# -----------------------------------------------------------------------------
# Comma-separated list of Telegram user IDs allowed to talk to Sean.
# Non-whitelisted users are silently ignored.
ALLOWED_TELEGRAM_USER_IDS=7341469970

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------
# Railway Postgres auto-injects this in production.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nordrise_ai?schema=public

# Public URL the Telegram webhook points to. Railway assigns this.
GATEWAY_PUBLIC_URL=https://nordrise-ai.up.railway.app

# HTTP port. Railway injects this; defaults to 3000 locally.
PORT=3000

# pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Behaviour tuning
# -----------------------------------------------------------------------------
# A new claude session is created after this many hours of inactivity.
SESSION_TIMEOUT_HOURS=24

# Per-invocation timeout for `claude -p`.
CLAUDE_CALL_TIMEOUT_MS=120000

# Sliding-window rate limit per user.
RATE_LIMIT_MAX_MESSAGES=20
RATE_LIMIT_WINDOW_MS=60000

# Absolute path inside the container where Sean has read/write access.
# Do not change unless you also update Railway volume mounts.
WORKSPACE_DIR=/app/workspace
